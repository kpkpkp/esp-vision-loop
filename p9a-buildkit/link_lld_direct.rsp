# LLD-adapted response file for direct ld.lld invocation
# Usage: ld.lld @link_lld_direct.rsp draw_frame.o -o app.elf
#
# Generated from link.rsp (GNU ld version)
# Key changes:
#   - -Wl, prefixes stripped (direct linker invocation)
#   - Compiler-only flags removed (-mlongcalls, -fno-*, etc.)
#   - Library list deduplicated (LLD resolves archive cycles automatically)
#   - --start-group/--end-group added for documentation (LLD treats as no-op)
#   - --no-warn-rwx-segments requires LLD 17+
#
# WARNING: LLD Xtensa support is experimental. If LLD cannot handle Xtensa
# relocations from the prebuilt ESP-IDF .a libraries, fall back to GNU ld.

# Linker flags
--cref
--defsym=IDF_TARGET_ESP32S3=0
--no-warn-rwx-segments
--gc-sections
--warn-common

# Linker scripts
-T /data/local/tmp/p9a-kit/p9a-buildkit/ld/esp32s3.peripherals.ld
-T /data/local/tmp/p9a-kit/p9a-buildkit/ld/esp32s3.rom.ld
-T /data/local/tmp/p9a-kit/p9a-buildkit/ld/esp32s3.rom.api.ld
-T /data/local/tmp/p9a-kit/p9a-buildkit/ld/esp32s3.rom.bt_funcs.ld
-T /data/local/tmp/p9a-kit/p9a-buildkit/ld/esp32s3.rom.libgcc.ld
-T /data/local/tmp/p9a-kit/p9a-buildkit/ld/esp32s3.rom.wdt.ld
-T /data/local/tmp/p9a-kit/p9a-buildkit/ld/esp32s3.rom.version.ld
-T /data/local/tmp/p9a-kit/p9a-buildkit/ld/esp32s3.rom.newlib.ld
-T /data/local/tmp/p9a-kit/p9a-buildkit/ld/memory.ld
-T /data/local/tmp/p9a-kit/p9a-buildkit/ld/sections.ld

# Object files
/data/local/tmp/p9a-kit/p9a-buildkit/obj/project_elf_src_esp32s3.c.obj

# Library search paths
-L/data/local/tmp/p9a-kit/p9a-buildkit/libs
-L/data/local/tmp/p9a-kit/p9a-buildkit/ld

# Force-undefined symbols (pull in constructor/init sections from archives)
-u esp_system_include_coredump_init
-u nvs_sec_provider_include_impl
-u esp_app_desc
-u esp_efuse_startup_include_func
-u ld_include_highint_hdl
-u start_app
-u start_app_other_cores
-u __ubsan_include
-u esp_system_include_startup_funcs
-u __assert_func
-u app_main
-u newlib_include_heap_impl
-u newlib_include_syscalls_impl
-u newlib_include_pthread_impl
-u newlib_include_assert_impl
-u newlib_include_init_funcs
-u pthread_include_pthread_impl
-u pthread_include_pthread_cond_var_impl
-u pthread_include_pthread_local_storage_impl
-u pthread_include_pthread_rwlock_impl
-u pthread_include_pthread_semaphore_impl
-u __cxa_guard_dummy
-u __cxx_init_dummy
-u __cxx_fatal_exception
-u esp_timer_init_include_func
-u uart_vfs_include_dev_init
-u usb_serial_jtag_vfs_include_dev_init
-u usb_serial_jtag_connection_monitor_include
-u include_esp_phy_override
-u esp_vfs_include_console_register
-u vfs_include_syscalls_impl

# Symbol wrapping
--wrap=longjmp
--wrap=__register_frame_info_bases
--wrap=__register_frame_info
--wrap=__register_frame
--wrap=__register_frame_info_table_bases
--wrap=__register_frame_info_table
--wrap=__register_frame_table
--wrap=__deregister_frame_info_bases
--wrap=__deregister_frame_info
--wrap=_Unwind_Find_FDE
--wrap=_Unwind_GetGR
--wrap=_Unwind_GetCFA
--wrap=_Unwind_GetIP
--wrap=_Unwind_GetIPInfo
--wrap=_Unwind_GetRegionStart
--wrap=_Unwind_GetDataRelBase
--wrap=_Unwind_GetTextRelBase
--wrap=_Unwind_SetIP
--wrap=_Unwind_SetGR
--wrap=_Unwind_GetLanguageSpecificData
--wrap=_Unwind_FindEnclosingFunction
--wrap=_Unwind_Resume
--wrap=_Unwind_RaiseException
--wrap=_Unwind_DeleteException
--wrap=_Unwind_ForcedUnwind
--wrap=_Unwind_Resume_or_Rethrow
--wrap=_Unwind_Backtrace
--wrap=__cxa_call_unexpected
--wrap=__gxx_personality_v0
--wrap=__cxa_throw
--wrap=__cxa_allocate_exception

--undefined=FreeRTOS_openocd_params

# Static libraries (single pass -- LLD resolves circular deps automatically)
